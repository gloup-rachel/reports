<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>리스페이스 퍼포먼스 대시보드</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0"></script>
<style>
:root {
  --bg-primary: #0f1117;
  --bg-secondary: #1a1d27;
  --bg-card: #1e2130;
  --bg-card-hover: #252840;
  --border: #2a2d3e;
  --text-primary: #e8eaed;
  --text-secondary: #9aa0b0;
  --text-muted: #6b7280;
  --accent-blue: #4f8cff;
  --accent-green: #34d399;
  --accent-yellow: #fbbf24;
  --accent-red: #f87171;
  --accent-purple: #a78bfa;
  --accent-orange: #fb923c;
  --naver-green: #03c75a;
  --google-blue: #4285f4;
  --meta-blue: #0668e1;
  --ga4-orange: #e37400;
  --shadow: 0 2px 8px rgba(0,0,0,0.3);
  --radius: 12px;
  --radius-sm: 8px;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Pretendard', 'Segoe UI', sans-serif; background: var(--bg-primary); color: var(--text-primary); min-height: 100vh; }
a { color: var(--accent-blue); text-decoration: none; }

/* Header */
.header { background: var(--bg-secondary); border-bottom: 1px solid var(--border); padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
.header-left { display: flex; align-items: center; gap: 16px; }
.logo { font-size: 20px; font-weight: 700; letter-spacing: -0.5px; }
.logo span { color: var(--accent-blue); }
.header-right { display: flex; align-items: center; gap: 16px; }
.status-badge { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-secondary); background: var(--bg-card); padding: 6px 12px; border-radius: 20px; border: 1px solid var(--border); }
.status-dot { width: 8px; height: 8px; border-radius: 50%; }
.status-dot.live { background: var(--accent-green); animation: pulse 2s infinite; }
.status-dot.stale { background: var(--accent-yellow); }
.status-dot.error { background: var(--accent-red); }
@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.4; } }
.view-toggle { display: flex; background: var(--bg-card); border-radius: var(--radius-sm); border: 1px solid var(--border); overflow: hidden; }
.view-toggle button { padding: 6px 16px; font-size: 13px; border: none; background: transparent; color: var(--text-secondary); cursor: pointer; transition: all 0.2s; }
.view-toggle button.active { background: var(--accent-blue); color: #fff; }
.admin-link { font-size: 13px; color: var(--text-secondary); padding: 6px 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); transition: all 0.2s; }
.admin-link:hover { border-color: var(--accent-blue); color: var(--accent-blue); }

/* Meta Bar */
.meta-bar { background: var(--bg-secondary); border-bottom: 1px solid var(--border); padding: 10px 32px; display: flex; align-items: center; gap: 24px; font-size: 12px; color: var(--text-muted); }
.meta-bar .label { color: var(--text-secondary); font-weight: 600; }

/* Tab Navigation */
.tab-nav { background: var(--bg-secondary); padding: 0 32px; display: flex; gap: 0; border-bottom: 2px solid var(--border); }
.tab-btn { padding: 14px 24px; font-size: 14px; font-weight: 600; color: var(--text-secondary); background: transparent; border: none; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all 0.2s; display: flex; align-items: center; gap: 8px; }
.tab-btn:hover { color: var(--text-primary); }
.tab-btn.active { color: var(--accent-blue); border-bottom-color: var(--accent-blue); }
.tab-btn .tab-icon { font-size: 16px; }

/* Main Content */
.main { padding: 24px 32px; max-width: 1440px; margin: 0 auto; }
.tab-content { display: none; }
.tab-content.active { display: block; }

/* Sub-tabs */
.sub-tabs { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
.sub-tab { padding: 8px 16px; font-size: 13px; border: 1px solid var(--border); border-radius: 20px; background: transparent; color: var(--text-secondary); cursor: pointer; transition: all 0.2s; }
.sub-tab:hover { border-color: var(--accent-blue); color: var(--text-primary); }
.sub-tab.active { background: var(--accent-blue); color: #fff; border-color: var(--accent-blue); }

/* KPI Cards */
.kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }
.kpi-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; transition: all 0.2s; }
.kpi-card:hover { border-color: var(--accent-blue); transform: translateY(-1px); }
.kpi-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
.kpi-value { font-size: 28px; font-weight: 700; margin-bottom: 4px; }
.kpi-sub { font-size: 12px; color: var(--text-secondary); }
.kpi-badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; }
.kpi-badge.good { background: rgba(52,211,153,0.15); color: var(--accent-green); }
.kpi-badge.warn { background: rgba(251,191,36,0.15); color: var(--accent-yellow); }
.kpi-badge.bad { background: rgba(248,113,113,0.15); color: var(--accent-red); }

/* Charts */
.chart-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
.chart-grid.full { grid-template-columns: 1fr; }
.chart-box { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
.chart-title { font-size: 14px; font-weight: 600; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
.chart-title .dot { width: 10px; height: 10px; border-radius: 50%; }
.chart-wrap { position: relative; height: 280px; }

/* Tables */
.data-table-wrap { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-bottom: 24px; }
.data-table-header { padding: 16px 20px; font-size: 14px; font-weight: 600; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
.data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.data-table th { padding: 10px 16px; text-align: left; font-weight: 600; color: var(--text-secondary); background: var(--bg-secondary); border-bottom: 1px solid var(--border); white-space: nowrap; cursor: pointer; user-select: none; }
.data-table th:hover { color: var(--text-primary); }
.data-table td { padding: 10px 16px; border-bottom: 1px solid var(--border); white-space: nowrap; }
.data-table tr:hover td { background: var(--bg-card-hover); }
.data-table .num { text-align: right; font-variant-numeric: tabular-nums; }

/* Insight Panel */
.insight-panel { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; margin-bottom: 24px; }
.insight-panel h3 { font-size: 14px; font-weight: 600; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
.insight-item { padding: 10px 14px; margin-bottom: 8px; background: var(--bg-secondary); border-radius: var(--radius-sm); border-left: 3px solid var(--accent-blue); font-size: 13px; line-height: 1.6; color: var(--text-secondary); }
.insight-item.warn { border-left-color: var(--accent-yellow); }
.insight-item.good { border-left-color: var(--accent-green); }
.insight-item.bad { border-left-color: var(--accent-red); }

/* Loading */
.loading { text-align: center; padding: 60px 20px; }
.spinner { width: 36px; height: 36px; border: 3px solid var(--border); border-top-color: var(--accent-blue); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 16px; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 14px; color: var(--text-secondary); }

/* Error */
.error-box { background: rgba(248,113,113,0.08); border: 1px solid rgba(248,113,113,0.3); border-radius: var(--radius); padding: 20px; text-align: center; color: var(--accent-red); }

/* Empty */
.empty { text-align: center; padding: 40px 20px; color: var(--text-muted); }

/* Scrollbar */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg-primary); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #3a3d4e; }

/* Responsive */
@media (max-width: 1024px) {
  .chart-grid { grid-template-columns: 1fr; }
  .header { padding: 12px 16px; }
  .main { padding: 16px; }
  .tab-nav { padding: 0 16px; overflow-x: auto; }
  .meta-bar { padding: 8px 16px; flex-wrap: wrap; }
}
@media (max-width: 640px) {
  .kpi-row { grid-template-columns: 1fr 1fr; }
  .header { flex-wrap: wrap; gap: 8px; }
}

/* Print */
@media print {
  body { background: #fff; color: #000; }
  .header, .tab-nav { position: static; }
  .kpi-card, .chart-box, .data-table-wrap, .insight-panel { break-inside: avoid; border-color: #ddd; }
}
</style>
</head>
<body>

<!-- Header -->
<header class="header">
  <div class="header-left">
    <div class="logo">RESPACE 퍼포먼스 대시보드</div>
  </div>
  <div class="header-right">
    <div class="status-badge">
      <div class="status-dot" id="statusDot"></div>
      <span id="statusText">연결 중...</span>
    </div>
    <div class="view-toggle">
      <button class="active" data-view="daily" onclick="setView('daily')">일자별</button>
      <button data-view="weekly" onclick="setView('weekly')">주차별</button>
    </div>
    <a class="admin-link" href="respace-admin.html">⚙ 어드민</a>
  </div>
</header>

<!-- Meta Bar -->
<div class="meta-bar">
  <span><span class="label">데이터 수집 기간:</span> <span id="dateRange">-</span></span>
  <span><span class="label">마지막 업데이트:</span> <span id="lastUpdated">-</span></span>
  <span><span class="label">데이터 소스:</span> Google Sheets (실시간 CSV)</span>
</div>

<!-- Tab Navigation -->
<nav class="tab-nav">
  <button class="tab-btn active" data-tab="search" onclick="switchTab('search')">
    <span class="tab-icon">🔍</span> 검색광고 인사이트
  </button>
  <button class="tab-btn" data-tab="meta" onclick="switchTab('meta')">
    <span class="tab-icon">📱</span> Meta 광고 인사이트
  </button>
  <button class="tab-btn" data-tab="ga4" onclick="switchTab('ga4')">
    <span class="tab-icon">📊</span> GA4 웹사이트 인사이트
  </button>
</nav>

<!-- Main Content -->
<div class="main">

  <!-- ===== 검색광고 탭 ===== -->
  <div class="tab-content active" id="tab-search">
    <div class="sub-tabs">
      <button class="sub-tab active" onclick="switchSubTab('search','naver-total')">네이버 통합</button>
      <button class="sub-tab" onclick="switchSubTab('search','naver-campaign')">네이버 캠페인별</button>
      <button class="sub-tab" onclick="switchSubTab('search','naver-keyword')">네이버 키워드별</button>
      <button class="sub-tab" onclick="switchSubTab('search','google-total')">구글 통합</button>
      <button class="sub-tab" onclick="switchSubTab('search','google-campaign')">구글 캠페인별</button>
      <button class="sub-tab" onclick="switchSubTab('search','google-keyword')">구글 키워드별</button>
    </div>
    <div id="search-content">
      <div class="loading"><div class="spinner"></div><div class="loading-text">검색광고 데이터를 불러오는 중...</div></div>
    </div>
  </div>

  <!-- ===== Meta 광고 탭 ===== -->
  <div class="tab-content" id="tab-meta">
    <div class="sub-tabs">
      <button class="sub-tab active" onclick="switchSubTab('meta','meta-total')">Meta 통합</button>
      <button class="sub-tab" onclick="switchSubTab('meta','meta-campaign')">캠페인별</button>
      <button class="sub-tab" onclick="switchSubTab('meta','meta-adset')">광고그룹(세트)별</button>
      <button class="sub-tab" onclick="switchSubTab('meta','meta-creative')">소재별</button>
    </div>
    <div id="meta-content">
      <div class="loading"><div class="spinner"></div><div class="loading-text">Meta 광고 데이터를 불러오는 중...</div></div>
    </div>
  </div>

  <!-- ===== GA4 탭 ===== -->
  <div class="tab-content" id="tab-ga4">
    <div class="sub-tabs">
      <button class="sub-tab active" onclick="switchSubTab('ga4','ga4-traffic')">GA4 트래픽</button>
      <button class="sub-tab" onclick="switchSubTab('ga4','ga4-conversion')">전환 액션</button>
    </div>
    <div id="ga4-content">
      <div class="loading"><div class="spinner"></div><div class="loading-text">GA4 데이터를 불러오는 중...</div></div>
    </div>
  </div>

</div>

<script>
// =====================================================
// CONFIGURATION
// =====================================================
const SPREADSHEET_ID = '1_J-qPpFpz5CjYv33a9pxZNBhyEgHfZtgK1upS-oZKbU';
const SHEETS = {
  naver: '네이버 검색광고',
  google: '구글 검색광고',
  meta: 'Meta 광고',
  ga4Traffic: 'GA4 트래픽',
  ga4Conversion: 'GA4 전환이벤트',
  leads: '리캐치_리드',
  deals: '리캐치_딜'
};

const BENCHMARKS = {
  google: { ctr: { good: 10, avg: 5 }, cpc: { good: 1000, avg: 1500 } },
  naver: { ctr: { good: 1.0, avg: 0.5 }, cpc: { good: 4000, avg: 5000 } },
  meta: { ctr: { good: 2.0, avg: 1.5 }, cpc: { good: 700, avg: 1000 } },
  conversion: { sessionRate: { good: 30, avg: 20 }, contactToDeal: { good: 15, avg: 7 }, downloadToLead: { good: 10, avg: 5 } }
};

const COLORS = {
  naver: '#03c75a', google: '#4285f4', meta: '#0668e1',
  blue: '#4f8cff', green: '#34d399', yellow: '#fbbf24',
  red: '#f87171', purple: '#a78bfa', orange: '#fb923c',
  cyan: '#22d3ee', pink: '#f472b6'
};
const CHART_PALETTE = ['#4f8cff','#34d399','#fbbf24','#f87171','#a78bfa','#fb923c','#22d3ee','#f472b6','#818cf8','#a3e635'];

// =====================================================
// STATE
// =====================================================
let rawData = {};
let currentView = 'daily'; // daily | weekly
let currentTab = 'search';
let currentSubTab = { search: 'naver-total', meta: 'meta-total', ga4: 'ga4-traffic' };
let charts = {};
let adminSettings = {};

// =====================================================
// CSV PARSER
// =====================================================
function parseCSV(text) {
  const lines = text.split('\n').filter(l => l.trim());
  if (lines.length === 0) return [];
  const headers = parseCsvLine(lines[0]);
  return lines.slice(1).map(line => {
    const vals = parseCsvLine(line);
    const obj = {};
    headers.forEach((h, i) => { obj[h.trim()] = (vals[i] || '').trim(); });
    return obj;
  });
}

function parseCsvLine(line) {
  const result = [];
  let current = '';
  let inQuotes = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (inQuotes) {
      if (ch === '"' && line[i+1] === '"') { current += '"'; i++; }
      else if (ch === '"') { inQuotes = false; }
      else { current += ch; }
    } else {
      if (ch === '"') { inQuotes = true; }
      else if (ch === ',') { result.push(current); current = ''; }
      else { current += ch; }
    }
  }
  result.push(current);
  return result;
}

function toNum(v) {
  if (!v) return 0;
  return parseFloat(String(v).replace(/[₩,%\s]/g, '').replace(/,/g, '')) || 0;
}

function fmt(n, type) {
  if (type === 'currency') return '₩' + Math.round(n).toLocaleString();
  if (type === 'percent') return n.toFixed(2) + '%';
  if (type === 'int') return Math.round(n).toLocaleString();
  return n.toLocaleString();
}

function badge(val, goodThreshold, badThreshold, inverse) {
  if (inverse) { // lower is better (e.g. CPC)
    if (val <= goodThreshold) return 'good';
    if (val >= badThreshold) return 'bad';
    return 'warn';
  }
  if (val >= goodThreshold) return 'good';
  if (val <= badThreshold) return 'bad';
  return 'warn';
}

// =====================================================
// DATA FETCHING
// =====================================================
function sheetUrl(sheetName) {
  return `https://docs.google.com/spreadsheets/d/${SPREADSHEET_ID}/gviz/tq?tqx=out:csv&sheet=${encodeURIComponent(sheetName)}`;
}

async function fetchSheet(name) {
  try {
    const res = await fetch(sheetUrl(SHEETS[name]));
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const text = await res.text();
    return parseCSV(text);
  } catch(e) {
    console.warn(`Sheet ${name} fetch failed:`, e);
    return null;
  }
}

async function fetchAllData() {
  updateStatus('loading', '데이터 로딩 중...');
  const keys = Object.keys(SHEETS);
  const results = await Promise.allSettled(keys.map(k => fetchSheet(k)));

  let successCount = 0;
  keys.forEach((k, i) => {
    if (results[i].status === 'fulfilled' && results[i].value) {
      rawData[k] = results[i].value;
      successCount++;
    }
  });

  if (successCount === 0) {
    updateStatus('error', '데이터 로드 실패');
    showError();
    return;
  }

  // Determine date range
  computeDateRange();
  updateStatus('live', `${successCount}/${keys.length} 시트 연결`);
  document.getElementById('lastUpdated').textContent = new Date().toLocaleString('ko-KR');

  // Load admin settings
  loadAdminSettings();

  // Render current tab
  renderAll();
}

function computeDateRange() {
  let minDate = null, maxDate = null;
  const dateFields = ['날짜', '일자', '일별', 'Date', '폼 제출 일자'];
  for (const key of Object.keys(rawData)) {
    const data = rawData[key];
    if (!data || data.length === 0) continue;
    const dateCol = Object.keys(data[0]).find(h => dateFields.some(f => h.includes(f)));
    if (!dateCol) continue;
    data.forEach(row => {
      const d = parseDate(row[dateCol]);
      if (d) {
        if (!minDate || d < minDate) minDate = d;
        if (!maxDate || d > maxDate) maxDate = d;
      }
    });
  }
  if (minDate && maxDate) {
    document.getElementById('dateRange').textContent =
      `${minDate.toLocaleDateString('ko-KR')} ~ ${maxDate.toLocaleDateString('ko-KR')}`;
  }
}

function parseDate(v) {
  if (!v) return null;
  const s = String(v).trim();
  // Try various formats
  const d = new Date(s);
  if (!isNaN(d)) return d;
  // Try YYYY.MM.DD or YYYY-MM-DD
  const m = s.match(/(\d{4})[.\-\/](\d{1,2})[.\-\/](\d{1,2})/);
  if (m) return new Date(m[1], m[2]-1, m[3]);
  return null;
}

function updateStatus(state, text) {
  const dot = document.getElementById('statusDot');
  const txt = document.getElementById('statusText');
  dot.className = 'status-dot ' + (state === 'loading' ? '' : state);
  txt.textContent = text;
}

function showError() {
  ['search-content','meta-content','ga4-content'].forEach(id => {
    document.getElementById(id).innerHTML = `
      <div class="error-box">
        <p style="font-size:16px;margin-bottom:8px;">데이터를 불러올 수 없습니다</p>
        <p style="font-size:13px;color:var(--text-secondary)">Google Sheets 접근 권한을 확인하거나, 시트가 "링크가 있는 모든 사용자"에게 공유되어 있는지 확인해주세요.</p>
      </div>`;
  });
}

// =====================================================
// ADMIN SETTINGS INTEGRATION
// =====================================================
function loadAdminSettings() {
  try {
    const s = localStorage.getItem('respace_admin_settings');
    if (s) {
      adminSettings = JSON.parse(s);
      // Apply saved view mode from admin
      if (adminSettings.view) {
        currentView = adminSettings.view;
        document.querySelectorAll('.view-toggle button').forEach(b => {
          b.classList.toggle('active', b.dataset.view === adminSettings.view);
        });
      }
    }
  } catch(e) { adminSettings = {}; }
}

// =====================================================
// VIEW & TAB SWITCHING
// =====================================================
function setView(view) {
  currentView = view;
  document.querySelectorAll('.view-toggle button').forEach(b => {
    b.classList.toggle('active', b.dataset.view === view);
  });
  renderAll();
}

function switchTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
  document.querySelectorAll('.tab-content').forEach(el => el.classList.toggle('active', el.id === 'tab-' + tab));
  renderAll();
}

function switchSubTab(tab, sub) {
  currentSubTab[tab] = sub;
  const parent = document.getElementById('tab-' + tab);
  parent.querySelectorAll('.sub-tab').forEach((b, i) => {
    const subs = getSubTabIds(tab);
    b.classList.toggle('active', subs[i] === sub);
  });
  renderAll();
}

function getSubTabIds(tab) {
  if (tab === 'search') return ['naver-total','naver-campaign','naver-keyword','google-total','google-campaign','google-keyword'];
  if (tab === 'meta') return ['meta-total','meta-campaign','meta-adset','meta-creative'];
  if (tab === 'ga4') return ['ga4-traffic','ga4-conversion'];
  return [];
}

// =====================================================
// RENDER ENGINE
// =====================================================
function renderAll() {
  // Destroy old charts
  Object.values(charts).forEach(c => { try { c.destroy(); } catch(e){} });
  charts = {};

  if (currentTab === 'search') renderSearch();
