// =====================================================
// AGGREGATION HELPERS
// =====================================================
function getDateCol(data) {
  if (!data || data.length === 0) return null;
  const fields = ['날짜', '일자', '일별', 'Date', '폼 제출 일자'];
  return Object.keys(data[0]).find(h => fields.some(f => h.includes(f))) || null;
}

function getWeekLabel(dateStr) {
  const d = parseDate(dateStr);
  if (!d) return 'Unknown';
  const month = d.getMonth() + 1;
  const dayOfMonth = d.getDate();
  const weekNum = Math.ceil(dayOfMonth / 7);
  return `${month}월 ${weekNum}주차`;
}

function aggregateByGroup(data, groupCol, metrics) {
  const groups = {};
  data.forEach(row => {
    const key = row[groupCol] || '(미분류)';
    if (!groups[key]) groups[key] = { _count: 0 };
    groups[key]._count++;
    metrics.forEach(m => {
      if (!groups[key][m.col]) groups[key][m.col] = 0;
      groups[key][m.col] += toNum(row[m.col]);
    });
  });
  return groups;
}

function aggregateTimeSeries(data, dateCol, metricCols) {
  const isWeekly = currentView === 'weekly';
  const grouped = {};
  data.forEach(row => {
    const key = isWeekly ? getWeekLabel(row[dateCol]) : row[dateCol];
    if (!grouped[key]) {
      grouped[key] = { label: key, _count: 0 };
      metricCols.forEach(m => { grouped[key][m] = 0; });
    }
    grouped[key]._count++;
    metricCols.forEach(m => { grouped[key][m] += toNum(row[m]); });
  });
  const entries = Object.values(grouped);
  if (!isWeekly) {
    entries.sort((a, b) => {
      const da = parseDate(a.label), db = parseDate(b.label);
      return (da || 0) - (db || 0);
    });
  }
  return entries;
}

function findColumns(data, keywords) {
  if (!data || data.length === 0) return {};
  const headers = Object.keys(data[0]);
  const result = {};
  keywords.forEach(kw => {
    const found = headers.find(h => h.includes(kw));
    if (found) result[kw] = found;
  });
  return result;
}

