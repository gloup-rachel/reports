      eventBreakdown[evName] += cnt;
    });
    const eventKeys = Object.keys(eventBreakdown).sort((a,b) => eventBreakdown[b] - eventBreakdown[a]);

    // Lead/Deal data
    const leadsData = rawData.leads;
    const dealsData = rawData.deals;
    let totalLeads = leadsData ? leadsData.length : 0;
    let totalDeals = dealsData ? dealsData.length : 0;

    const contactEvents = eventBreakdown['click_contact'] || 0;
    const downloadEvents = eventBreakdown['click_download_intro'] || eventBreakdown['click_download'] || 0;
    const contactToDeal = contactEvents > 0 ? (totalDeals / contactEvents * 100) : 0;
    const downloadToLead = downloadEvents > 0 ? (totalLeads / downloadEvents * 100) : 0;

    let html = `
    <div class="kpi-row">
      <div class="kpi-card">
        <div class="kpi-label">총 전환이벤트</div>
        <div class="kpi-value" style="color:var(--accent-green)">${fmt(totalEvents, 'int')}</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">상담문의 (click_contact)</div>
        <div class="kpi-value">${fmt(contactEvents, 'int')}</div>
        <div class="kpi-sub">→ 딜 ${totalDeals}건 (${fmt(contactToDeal, 'percent')})</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">소개서 다운 (click_download)</div>
        <div class="kpi-value">${fmt(downloadEvents, 'int')}</div>
        <div class="kpi-sub">→ 리드 ${totalLeads}건 (${fmt(downloadToLead, 'percent')})</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">총 리드+딜</div>
        <div class="kpi-value" style="color:var(--accent-purple)">${fmt(totalLeads + totalDeals, 'int')}</div>
      </div>
    </div>`;

    // Event breakdown chart + time series
    html += `
    <div class="chart-grid">
      <div class="chart-box">
        <div class="chart-title"><span class="dot" style="background:var(--accent-green)"></span>전환이벤트 유형별 비중</div>
        <div class="chart-wrap"><canvas id="conv-event-chart"></canvas></div>
      </div>
      <div class="chart-box">
        <div class="chart-title"><span class="dot" style="background:var(--accent-blue)"></span>Y형 전환 퍼널</div>
        <div class="chart-wrap" style="display:flex;align-items:center;justify-content:center;">
          <div style="text-align:center;font-size:13px;line-height:2.2;">
            <div style="font-size:18px;font-weight:700;color:var(--accent-blue)">세션 ${fmt(rawData.ga4Traffic ? rawData.ga4Traffic.reduce((s,r) => s + toNum(r[Object.keys(r).find(h=>h.includes('세션'))]), 0) : 0, 'int')}</div>
            <div style="color:var(--text-muted)">↓</div>
            <div style="font-size:16px;font-weight:600;color:var(--accent-green)">전환이벤트 ${fmt(totalEvents, 'int')}</div>
            <div style="display:flex;gap:40px;justify-content:center;margin-top:8px;">
              <div>
                <div style="color:var(--accent-orange)">↙ 상담문의</div>
                <div style="font-weight:700">${fmt(contactEvents,'int')} → 딜 ${totalDeals}</div>
                <div style="color:var(--text-muted);font-size:11px">${fmt(contactToDeal,'percent')}</div>
              </div>
              <div>
                <div style="color:var(--accent-purple)">↘ 소개서</div>
                <div style="font-weight:700">${fmt(downloadEvents,'int')} → 리드 ${totalLeads}</div>
                <div style="color:var(--text-muted);font-size:11px">${fmt(downloadToLead,'percent')}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>`;

    // Event table
    html += `
    <div class="data-table-wrap">
      <div class="data-table-header">전환이벤트 상세</div>
      <div style="overflow-x:auto">
      <table class="data-table">
        <thead><tr><th>이벤트명</th><th class="num">횟수</th><th class="num">비중</th></tr></thead>
        <tbody>
        ${eventKeys.map(k => `<tr>
          <td>${k}</td>
          <td class="num">${fmt(eventBreakdown[k], 'int')}</td>
          <td class="num">${totalEvents > 0 ? fmt(eventBreakdown[k] / totalEvents * 100, 'percent') : '-'}</td>
        </tr>`).join('')}
        </tbody>
      </table>
      </div>
    </div>`;

    html += renderInsightPanel('insight_ga4_conv', 'GA4 전환 인사이트');
    container.innerHTML = html;

    if (eventKeys.length > 0) {
      charts['conv-event'] = createChart('conv-event-chart', 'doughnut', eventKeys.slice(0, 8), [{
        data: eventKeys.slice(0, 8).map(k => eventBreakdown[k]),
        backgroundColor: CHART_PALETTE.slice(0, 8),
        borderWidth: 0
      }], { cutout: '55%' });
    }
  }
}

// =====================================================
// SHARED RENDERERS
// =====================================================
function renderGroupTable(container, data, groupCol, metricCols, title, color, insightKey) {
  if (!groupCol) {
    container.innerHTML = '<div class="empty">해당 컬럼 데이터가 없습니다.</div>';
    return;
  }

  const validCols = metricCols.filter(Boolean);
  const groups = {};
  data.forEach(row => {
    const key = row[groupCol] || '(미분류)';
    if (!groups[key]) { groups[key] = {}; validCols.forEach(c => groups[key][c] = 0); }
    validCols.forEach(c => { groups[key][c] += toNum(row[c]); });
  });

  const keys = Object.keys(groups).sort((a, b) => {
    const ca = validCols[1]; // sort by clicks
    return (groups[b][ca] || 0) - (groups[a][ca] || 0);
  });

  const impCol = validCols[0];
  const clickCol = validCols[1];
  const costCol = validCols[2];
  const convCol = validCols[3];

  // Chart
  let html = `
  <div class="chart-grid">
    <div class="chart-box">
      <div class="chart-title"><span class="dot" style="background:${color}"></span>${title} — 클릭수</div>
      <div class="chart-wrap"><canvas id="group-chart"></canvas></div>
    </div>
    <div class="chart-box">
      <div class="chart-title"><span class="dot" style="background:var(--accent-yellow)"></span>${title} — CPC</div>
      <div class="chart-wrap"><canvas id="group-cpc-chart"></canvas></div>
    </div>
  </div>`;

  // Table
  html += `
  <div class="data-table-wrap">
    <div class="data-table-header">${title}</div>
    <div style="overflow-x:auto">
    <table class="data-table">
      <thead><tr>
        <th>${groupCol}</th>
        ${impCol ? '<th class="num">노출수</th>' : ''}
        ${clickCol ? '<th class="num">클릭수</th>' : ''}
        ${costCol ? '<th class="num">광고비</th>' : ''}
        ${clickCol && impCol ? '<th class="num">CTR</th>' : ''}
        ${clickCol && costCol ? '<th class="num">CPC</th>' : ''}
        ${convCol ? '<th class="num">전환수</th>' : ''}
      </tr></thead>
      <tbody>
      ${keys.map(k => {
        const g = groups[k];
        const ctr = g[impCol] > 0 ? (g[clickCol] / g[impCol] * 100) : 0;
        const cpc = g[clickCol] > 0 ? (g[costCol] / g[clickCol]) : 0;
        return `<tr>
          <td>${k}</td>
          ${impCol ? `<td class="num">${fmt(g[impCol], 'int')}</td>` : ''}
          ${clickCol ? `<td class="num">${fmt(g[clickCol], 'int')}</td>` : ''}
          ${costCol ? `<td class="num">${fmt(g[costCol], 'currency')}</td>` : ''}
          ${clickCol && impCol ? `<td class="num">${fmt(ctr, 'percent')}</td>` : ''}
          ${clickCol && costCol ? `<td class="num">${fmt(cpc, 'currency')}</td>` : ''}
          ${convCol ? `<td class="num">${fmt(g[convCol], 'int')}</td>` : ''}
        </tr>`;
      }).join('')}
      </tbody>
    </table>
    </div>
  </div>`;

  html += renderInsightPanel(insightKey, '인사이트');
  container.innerHTML = html;

  // Charts
  const topKeys = keys.slice(0, 10);
  charts['group'] = createChart('group-chart', 'bar', topKeys, [{
    label: '클릭수',
    data: topKeys.map(k => groups[k][clickCol] || 0),
    backgroundColor: CHART_PALETTE.slice(0, topKeys.length).map(c => c + '80'),
    borderColor: CHART_PALETTE.slice(0, topKeys.length),
    borderWidth: 1
  }]);

  if (clickCol && costCol) {
    charts['group-cpc'] = createChart('group-cpc-chart', 'bar', topKeys, [{
      label: 'CPC (원)',
      data: topKeys.map(k => groups[k][clickCol] ? Math.round(groups[k][costCol] / groups[k][clickCol]) : 0),
      backgroundColor: CHART_PALETTE.slice(0, topKeys.length).map(c => c + '60'),
      borderColor: CHART_PALETTE.slice(0, topKeys.length),
      borderWidth: 1
    }]);
  }
}

function renderInsightPanel(key, title) {
  const insight = adminSettings[key] || '';
  if (!insight) {
    return `<div class="insight-panel">
      <h3>💡 ${title}</h3>
      <div class="insight-item" style="border-left-color:var(--text-muted)">어드민 페이지에서 인사이트를 입력하면 여기에 표시됩니다.</div>
    </div>`;
  }
  const lines = insight.split('\n').filter(l => l.trim());
  return `<div class="insight-panel">
    <h3>💡 ${title}</h3>
    ${lines.map(l => `<div class="insight-item">${l}</div>`).join('')}
  </div>`;
}

// =====================================================
// CHART.JS WRAPPER
// =====================================================
function createChart(canvasId, type, labels, datasets, extraOpts = {}) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return null;
  const ctx = canvas.getContext('2d');

  const isDoughnut = type === 'doughnut';
  const opts = {
    responsive: true,
    maintainAspectRatio: false,
    interaction: { mode: isDoughnut ? 'nearest' : 'index', intersect: false },
    plugins: {
      legend: {
        display: isDoughnut || datasets.length > 1,
        position: isDoughnut ? 'right' : 'top',
        labels: { color: '#9aa0b0', usePointStyle: true, padding: 12, font: { size: 11 } }
      },
      tooltip: {
        backgroundColor: '#1e2130',
        titleColor: '#e8eaed',
        bodyColor: '#9aa0b0',
        borderColor: '#2a2d3e',
        borderWidth: 1,
        padding: 10,
        callbacks: {
          label: function(ctx) {
            let val = ctx.parsed.y !== undefined ? ctx.parsed.y : ctx.parsed;
            if (typeof val === 'number') val = val.toLocaleString();
            return `${ctx.dataset.label || ''}: ${val}`;
          }
        }
      }
    },
    scales: isDoughnut ? {} : {
      x: {
        grid: { color: '#1a1d2720' },
        ticks: { color: '#6b7280', font: { size: 11 }, maxRotation: 45 }
      },
      y: {
        grid: { color: '#2a2d3e40' },
        ticks: { color: '#6b7280', font: { size: 11 }, callback: v => v >= 1000 ? (v/1000).toFixed(0) + 'K' : v }
      }
    },
    ...extraOpts
  };

  if (isDoughnut && extraOpts.cutout) {
    opts.cutout = extraOpts.cutout;
    delete opts.scales;
  }

  datasets.forEach(ds => {
    if (type === 'line' && !ds.pointRadius) ds.pointRadius = 2;
    if (type === 'line' && !ds.tension) ds.tension = 0.3;
  });

  return new Chart(ctx, { type, data: { labels, datasets }, options: opts });
}

